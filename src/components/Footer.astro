---
import siteMeta from '../data/site-meta.json';
import { categories } from '../data/categories';
import Logo from './Logo.astro';
import Icon from './Icon.astro';
---

<footer class="site-footer" role="contentinfo">
  <div class="site-footer__inner">
    <div class="site-footer__cols">
      <!-- ブランド列 -->
      <div class="site-footer__brand">
        <div class="site-footer__brand-logo">
          <Logo variant="light" size="md" />
        </div>
        <p class="site-footer__desc">{siteMeta.tagline}</p>
      </div>

      <!-- テンプレ列 -->
      <div>
        <h3 class="site-footer__heading">テンプレート</h3>
        <ul class="site-footer__links">
          {categories.map(cat => (
            <li>
              <a href={`/${cat.slug}/`}>
                <Icon name="chevron-right" size={12} />
                {cat.shortName}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- 運営情報列 -->
      <div>
        <h3 class="site-footer__heading">運営情報</h3>
        <ul class="site-footer__links">
          <li>
            <a href="/about/">
              <Icon name="chevron-right" size={12} />
              運営者情報
            </a>
          </li>
          <li>
            <a href="/contact/">
              <Icon name="chevron-right" size={12} />
              お問い合わせ
            </a>
          </li>
          <li>
            <a href="/privacy/">
              <Icon name="chevron-right" size={12} />
              プライバシーポリシー
            </a>
          </li>
          <li>
            <a href="/disclaimer/">
              <Icon name="chevron-right" size={12} />
              免責事項
            </a>
          </li>
        </ul>
      </div>

      <!-- グループサイト列 -->
      <div>
        <h3 class="site-footer__heading">グループサイト</h3>
        {siteMeta.groupSites.map(site => (
          <div class="site-footer__group-card">
            <a href={site.url} class="site-footer__group-name" target="_blank" rel="noopener noreferrer">
              {site.name}
              <Icon name="external-link" size={11} />
            </a>
            <span class="site-footer__group-desc">{site.description}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="site-footer__bottom">
      <span>&copy; 2026 {siteMeta.siteName}. All rights reserved.</span>
      <div class="site-footer__bottom-links">
        <a href="/privacy/">プライバシーポリシー</a>
        <a href="/disclaimer/">免責事項</a>
        <a href="/contact/">お問い合わせ</a>
      </div>
    </div>
  </div>
</footer>
