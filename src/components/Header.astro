---
import siteMeta from '../data/site-meta.json';
import { categories } from '../data/categories';
import { getCategoryNavItems } from '../data/templates';
import type { CategorySlug } from '../data/templates';
import Logo from './Logo.astro';
import Icon from './Icon.astro';

// ヘッダー用にカテゴリデータを事前計算
const navItems = categories.map(cat => ({
  ...cat,
  nav: getCategoryNavItems(cat.slug as CategorySlug),
}));
---

<header class="site-header" role="banner">
  <div class="site-header__inner">
    <a href="/" class="site-logo" aria-label={`${siteMeta.siteName} ホームへ`}>
      <Logo variant="dark" size="md" />
    </a>

    <nav class="site-nav" aria-label="メインナビゲーション">
      {navItems.map(cat => (
        <div class="nav-item" data-nav-item>
          <a
            href={`/${cat.slug}/`}
            class="nav-item__link"
            aria-haspopup="true"
            aria-expanded="false"
          >
            {cat.shortName}
            <Icon name="chevron-down" size={13} class="nav-item__chevron" aria-hidden="true" />
          </a>
          <div class="nav-dropdown" aria-hidden="true" role="region" aria-label={`${cat.name}のメニュー`}>
            <div class="nav-dropdown__head">
              <h3 class="nav-dropdown__title">{cat.name}</h3>
              <span class="nav-dropdown__count">
                公開中 {cat.nav.published.length} 件
                {cat.nav.upcoming.length > 0 && `/ 準備中 ${cat.nav.upcoming.length} 件`}
              </span>
            </div>
            <ul class="nav-dropdown__list" role="list">
              {cat.nav.published.map(t => (
                <li class="nav-dropdown__item">
                  <a href={t.url} class="nav-dropdown__link">
                    <Icon name="document" size={14} class="nav-dropdown__link-icon" aria-hidden="true" />
                    <span class="nav-dropdown__link-text">{t.shortTitle}</span>
                  </a>
                </li>
              ))}
              {cat.nav.upcoming.map(t => (
                <li class="nav-dropdown__item nav-dropdown__item--disabled" aria-disabled="true">
                  <span class="nav-dropdown__link-disabled">
                    <Icon name="document" size={14} class="nav-dropdown__link-icon" aria-hidden="true" />
                    <span class="nav-dropdown__link-text">{t.title}</span>
                    <span class="nav-dropdown__badge">準備中</span>
                  </span>
                </li>
              ))}
            </ul>
            <a href={`/${cat.slug}/`} class="nav-dropdown__more">
              {cat.shortName}の一覧を見る
              <Icon name="arrow-right" size={13} aria-hidden="true" />
            </a>
          </div>
        </div>
      ))}
      <a href="/about/" class="nav-item__link nav-item__link--plain">運営情報</a>
    </nav>

    <a href="/#categories" class="site-cta" aria-label="無料テンプレート一覧を見る">
      <Icon name="document" size={15} />
      無料テンプレ一覧
    </a>

    <!-- モバイルハンバーガー -->
    <button
      class="mobile-menu-btn"
      aria-label="メニューを開く"
      aria-expanded="false"
      aria-controls="mobile-menu"
      id="menu-toggle"
    >
      <Icon name="menu" size={22} />
    </button>
  </div>
</header>

<!-- モバイルメニュー -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <div class="mobile-menu__inner">
    <div class="mobile-menu__head">
      <Logo variant="dark" size="sm" />
      <button class="mobile-menu__close" id="menu-close" aria-label="メニューを閉じる">
        <Icon name="x" size={22} />
      </button>
    </div>
    <nav class="mobile-menu__nav" aria-label="モバイルナビゲーション">
      {categories.map(cat => (
        <a href={`/${cat.slug}/`} class="mobile-menu__link">
          <Icon name="chevron-right" size={16} />
          {cat.shortName}
        </a>
      ))}
      <a href="/about/" class="mobile-menu__link">
        <Icon name="chevron-right" size={16} />
        運営情報
      </a>
    </nav>
    <div class="mobile-menu__cta">
      <a href="/#categories" class="mobile-menu__cta-btn">
        <Icon name="document" size={18} />
        無料テンプレート一覧
      </a>
    </div>
  </div>
</div>
<div class="mobile-menu__overlay" id="menu-overlay"></div>

<style>
/* ============================================================
   ナビアイテム（ドロップダウン付き）
   ============================================================ */
.nav-item {
  position: relative;
}

.nav-item__link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: var(--color-muted);
  font-weight: 500;
  font-size: 13.5px;
  padding: 8px 14px;
  border-radius: var(--radius-sm);
  letter-spacing: 0.02em;
  text-decoration: none;
  transition: color var(--transition-base), background var(--transition-base);
  position: relative;
  white-space: nowrap;
  cursor: pointer;
  background: none;
  border: none;
}

/* ゴールドアンダーライン（既存デザイン継承） */
.nav-item__link::after {
  content: '';
  position: absolute;
  bottom: 4px;
  left: 14px;
  right: 14px;
  height: 1px;
  background: var(--color-gold);
  transform: scaleX(0);
  transition: transform var(--transition-base);
  transform-origin: left;
}
.nav-item__link:hover,
.nav-item:hover > .nav-item__link {
  color: var(--color-navy);
  opacity: 1;
}
.nav-item__link:hover::after,
.nav-item:hover > .nav-item__link::after {
  transform: scaleX(1);
}

/* 「運営情報」は chevron なし */
.nav-item__link--plain {
  color: var(--color-muted);
}

/* chevron アイコン: ホバーで 180度回転 */
.nav-item__chevron {
  transition: transform var(--transition-base);
  flex-shrink: 0;
  margin-left: 1px;
}
.nav-item:hover > .nav-item__link .nav-item__chevron {
  transform: rotate(180deg);
}

/* ============================================================
   ドロップダウン本体
   ============================================================ */
.nav-dropdown {
  position: absolute;
  top: calc(100% + 6px);
  left: 50%;
  transform: translateX(-50%);
  width: 340px;
  background: #fff;
  border: 1px solid var(--color-border-light);
  border-top: 2px solid var(--color-gold);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-elevated);
  z-index: 300;
  /* 初期状態: 非表示 */
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transform: translateX(-50%) translateY(6px);
  transition:
    opacity 0.15s ease,
    transform 0.15s ease,
    visibility 0.15s ease;
}

/* ホバー時: 表示 */
.nav-item:hover > .nav-dropdown,
.nav-dropdown:hover {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}

/* ドロップダウンとナビアイテムの間にマウス移動ギャップを埋めるブリッジ */
.nav-item::after {
  content: '';
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  height: 8px;
  background: transparent;
}

/* ドロップダウンヘッド */
.nav-dropdown__head {
  padding: 14px 16px 10px;
  border-bottom: 1px solid var(--color-border-light);
}
.nav-dropdown__title {
  font-family: var(--font-serif);
  font-size: 13px;
  font-weight: 700;
  color: var(--color-heading);
  margin: 0 0 3px;
  line-height: 1.3;
  letter-spacing: 0.02em;
}
.nav-dropdown__count {
  font-size: 11px;
  color: var(--color-muted);
  font-weight: 500;
}

/* リスト */
.nav-dropdown__list {
  list-style: none;
  margin: 6px 0;
  padding: 0 6px;
  max-height: 280px;
  overflow-y: auto;
}

.nav-dropdown__item {
  margin: 1px 0;
}

/* 公開中アイテム */
.nav-dropdown__link {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  border-radius: var(--radius-sm);
  color: var(--color-text);
  font-size: 13px;
  font-weight: 500;
  text-decoration: none;
  transition: background var(--transition-base), color var(--transition-base);
  min-height: 36px;
}
.nav-dropdown__link:hover {
  background: var(--color-gold-pale);
  color: var(--color-navy);
  opacity: 1;
}
.nav-dropdown__link-icon {
  color: var(--color-gold);
  flex-shrink: 0;
}
.nav-dropdown__link:hover .nav-dropdown__link-icon {
  color: var(--color-navy);
}
.nav-dropdown__link-text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

/* 準備中アイテム */
.nav-dropdown__item--disabled {
  pointer-events: none;
}
.nav-dropdown__link-disabled {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  border-radius: var(--radius-sm);
  color: var(--color-subtle);
  font-size: 13px;
  font-weight: 400;
  cursor: default;
  min-height: 36px;
}
.nav-dropdown__link-disabled .nav-dropdown__link-icon {
  color: var(--color-border);
}
.nav-dropdown__badge {
  font-size: 10px;
  font-weight: 700;
  color: var(--color-subtle);
  background: var(--color-bg-section);
  border: 1px solid var(--color-border-light);
  padding: 2px 6px;
  border-radius: var(--radius-xs);
  letter-spacing: 0.06em;
  white-space: nowrap;
  flex-shrink: 0;
  margin-left: auto;
}

/* フッターリンク */
.nav-dropdown__more {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6px;
  padding: 10px 16px 12px;
  margin: 0 0 2px;
  border-top: 1px solid var(--color-border-light);
  color: var(--color-navy);
  font-size: 12px;
  font-weight: 700;
  text-decoration: none;
  letter-spacing: 0.02em;
  transition: color var(--transition-base), background var(--transition-base);
  border-radius: 0 0 var(--radius-lg) var(--radius-lg);
}
.nav-dropdown__more:hover {
  background: var(--color-gold-pale);
  color: var(--color-navy);
  opacity: 1;
}
.nav-dropdown__more svg {
  flex-shrink: 0;
  transition: transform var(--transition-base);
  color: var(--color-gold);
}
.nav-dropdown__more:hover svg {
  transform: translateX(3px);
}

/* PCのみ表示 */
@media (max-width: 768px) {
  .nav-dropdown { display: none; }
}

/* ============================================================
   モバイルハンバーガー
   ============================================================ */
.mobile-menu-btn {
  display: none;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border: none;
  background: none;
  color: var(--color-navy);
  cursor: pointer;
  border-radius: var(--radius-sm);
  transition: background var(--transition-base);
  padding: 0;
}
.mobile-menu-btn:hover { background: var(--color-bg-section); }
@media (max-width: 768px) { .mobile-menu-btn { display: flex; } }

/* ============================================================
   Mobile Menu
   ============================================================ */
.mobile-menu {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  width: min(360px, 90vw);
  background: var(--color-bg);
  z-index: 500;
  transform: translateX(100%);
  transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-hover);
}
.mobile-menu.open { transform: translateX(0); }
.mobile-menu[aria-hidden="true"] { pointer-events: none; }
.mobile-menu[aria-hidden="false"] { pointer-events: auto; }

.mobile-menu__overlay {
  position: fixed;
  inset: 0;
  background: rgba(10,22,40,0.5);
  z-index: 490;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
  backdrop-filter: blur(2px);
}
.mobile-menu__overlay.open { opacity: 1; pointer-events: auto; }

.mobile-menu__inner {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow-y: auto;
}
.mobile-menu__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 20px;
  border-bottom: 1px solid var(--color-border-light);
}
.mobile-menu__close {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  background: none;
  color: var(--color-muted);
  cursor: pointer;
  border-radius: var(--radius-sm);
  padding: 0;
  transition: background var(--transition-base);
}
.mobile-menu__close:hover { background: var(--color-bg-section); color: var(--color-navy); }
.mobile-menu__nav {
  flex: 1;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}
.mobile-menu__link {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px;
  color: var(--color-text);
  font-size: 15px;
  font-weight: 600;
  text-decoration: none;
  border-radius: var(--radius-md);
  transition: background var(--transition-base), color var(--transition-base);
}
.mobile-menu__link svg { color: var(--color-border); }
.mobile-menu__link:hover {
  background: var(--color-gold-pale);
  color: var(--color-navy);
  opacity: 1;
}
.mobile-menu__link:hover svg { color: var(--color-gold); }
.mobile-menu__cta {
  padding: 16px;
  border-top: 1px solid var(--color-border-light);
}
.mobile-menu__cta-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  padding: 16px;
  background: var(--color-navy);
  color: #fff;
  font-size: 15px;
  font-weight: 700;
  text-decoration: none;
  border-radius: var(--radius-md);
  letter-spacing: 0.02em;
  transition: background var(--transition-base);
}
.mobile-menu__cta-btn:hover { background: var(--color-navy-mid); color: #fff; opacity: 1; }
</style>

<script is:inline>
(function() {
  // =============================================
  // モバイルメニュー
  // =============================================
  var toggle = document.getElementById('menu-toggle');
  var closeBtn = document.getElementById('menu-close');
  var menu = document.getElementById('mobile-menu');
  var overlay = document.getElementById('menu-overlay');

  function openMenu() {
    menu.classList.add('open');
    menu.setAttribute('aria-hidden', 'false');
    overlay.classList.add('open');
    toggle.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    menu.classList.remove('open');
    menu.setAttribute('aria-hidden', 'true');
    overlay.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  if (toggle) toggle.addEventListener('click', openMenu);
  if (closeBtn) closeBtn.addEventListener('click', closeMenu);
  if (overlay) overlay.addEventListener('click', closeMenu);
  if (menu) menu.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeMenu); });

  // =============================================
  // メガメニュー: キーボード + aria-expanded 管理
  // =============================================
  var navItems = document.querySelectorAll('[data-nav-item]');

  navItems.forEach(function(item) {
    var link = item.querySelector('.nav-item__link');
    var dropdown = item.querySelector('.nav-dropdown');
    if (!link || !dropdown) return;

    // ホバーで aria-expanded を切り替え
    item.addEventListener('mouseenter', function() {
      link.setAttribute('aria-expanded', 'true');
      dropdown.setAttribute('aria-hidden', 'false');
    });
    item.addEventListener('mouseleave', function() {
      link.setAttribute('aria-expanded', 'false');
      dropdown.setAttribute('aria-hidden', 'true');
    });

    // フォーカスでも展開（Tab ナビゲーション）
    link.addEventListener('focus', function() {
      link.setAttribute('aria-expanded', 'true');
      dropdown.setAttribute('aria-hidden', 'false');
    });

    // ドロップダウン内の最後のリンクで Tab を押すと閉じる
    var dropLinks = dropdown.querySelectorAll('a');
    if (dropLinks.length > 0) {
      dropLinks[dropLinks.length - 1].addEventListener('keydown', function(e) {
        if (e.key === 'Tab' && !e.shiftKey) {
          link.setAttribute('aria-expanded', 'false');
          dropdown.setAttribute('aria-hidden', 'true');
        }
      });
    }

    // Escape で閉じる
    item.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        link.setAttribute('aria-expanded', 'false');
        dropdown.setAttribute('aria-hidden', 'true');
        link.focus();
      }
    });
  });

  // グローバル Escape（モバイルメニューも閉じる）
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeMenu();
  });
})();
</script>
