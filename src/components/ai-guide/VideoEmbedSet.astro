---
import Icon from '../Icon.astro';

interface VideoItem {
  /** ツール名（例: "Runway Gen-3"） */
  tool: string;
  /** ロゴURL or サムネ（任意） */
  toolLogo?: string;
  /** 入力プロンプト（共通プロンプトを各カードで再掲） */
  prompt?: string;
  /** 埋め込みURL（YouTube/Vimeo/MP4直URL） */
  embedUrl: string;
  /** MP4等の場合のtypeヒント（"video/mp4"等） */
  embedType?: 'iframe' | 'video';
  /** ポスター画像（typeがvideoの場合） */
  poster?: string;
  /** メモ・特記事項 */
  note?: string;
  /** 実機検証準備中フラグ（trueの場合は動画埋め込み代わりにプレースホルダ表示） */
  comingSoon?: boolean;
  /** 公式デモ動画フラグ（trueの場合は出典バッジを表示） */
  isOfficial?: boolean;
  /** 出典ラベル（公式チャンネル名等） */
  sourceLabel?: string;
  /** 出典URL（公式チャンネルURL） */
  sourceUrl?: string;
  /** 公開日（YYYY-MM-DD） */
  publishedDate?: string;
}

interface Props {
  /** 共通プロンプト（タイトル下に1回掲載） */
  sharedPrompt?: string;
  /** 動画群 */
  videos: VideoItem[];
  /** セクション見出し（任意） */
  heading?: string;
}

const { sharedPrompt, videos, heading } = Astro.props;
---

<section class="video-embed-set" aria-label={heading || '同一プロンプトでのツール比較動画'}>
  {heading && (
    <h3 class="video-embed-set__heading">
      <Icon name="sparkle" size={16} aria-hidden="true" />
      {heading}
    </h3>
  )}

  {sharedPrompt && (
    <div class="video-embed-set__shared" aria-label="共通プロンプト">
      <span class="video-embed-set__shared-label">入力プロンプト（共通）</span>
      <p class="video-embed-set__shared-text">{sharedPrompt}</p>
    </div>
  )}

  <div class="video-embed-set__grid">
    {videos.map((video, idx) => (
      <article class="video-card" aria-labelledby={`video-${idx}-title`}>
        <header class="video-card__head">
          <span class="video-card__num" aria-hidden="true">#{String(idx + 1).padStart(2, '0')}</span>
          <h4 class="video-card__tool" id={`video-${idx}-title`}>{video.tool}</h4>
        </header>

        <div class="video-card__media">
          {video.comingSoon ? (
            <div class="video-card__coming-soon" role="status" aria-label="実機検証準備中">
              <span class="video-card__coming-soon-icon" aria-hidden="true">
                <Icon name="sparkle" size={20} />
              </span>
              <span class="video-card__coming-soon-text">
                実機検証準備中
              </span>
              <span class="video-card__coming-soon-sub">
                Coming Soon
              </span>
            </div>
          ) : video.embedType === 'video' ? (
            <video
              controls
              preload="none"
              poster={video.poster}
              class="video-card__video"
              playsinline
            >
              <source src={video.embedUrl} type="video/mp4" />
              お使いのブラウザは動画再生に対応していません。
            </video>
          ) : (
            <iframe
              src={video.embedUrl}
              title={`${video.tool} 生成動画`}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              class="video-card__iframe"
              referrerpolicy="strict-origin-when-cross-origin"
            ></iframe>
          )}
        </div>

        {(video.prompt || video.note || video.isOfficial) && (
          <footer class="video-card__foot">
            {video.isOfficial && video.sourceLabel && (
              <p class="video-card__source">
                <span class="video-card__source-badge" aria-label="公式デモ動画">公式</span>
                {video.sourceUrl ? (
                  <a
                    href={video.sourceUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="video-card__source-link"
                  >
                    {video.sourceLabel}提供
                  </a>
                ) : (
                  <span class="video-card__source-text">{video.sourceLabel}提供</span>
                )}
                {video.publishedDate && (
                  <span class="video-card__source-date">公開日: {video.publishedDate}</span>
                )}
              </p>
            )}
            {video.prompt && (
              <p class="video-card__prompt">
                <span class="video-card__prompt-label">{video.isOfficial ? '注釈:' : 'プロンプト:'}</span>
                {video.prompt}
              </p>
            )}
            {video.note && (
              <p class="video-card__note">{video.note}</p>
            )}
          </footer>
        )}
      </article>
    ))}
  </div>
</section>

<style>
  .video-embed-set {
    margin: 32px 0;
  }
  .video-embed-set__heading {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 14px;
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--color-heading);
    line-height: 1.5;
  }
  .video-embed-set__heading svg {
    color: var(--color-gold);
    flex-shrink: 0;
  }
  .video-embed-set__shared {
    margin-bottom: 18px;
    padding: 14px 16px;
    background: var(--color-bg-section);
    border-left: 3px solid var(--color-gold);
    border-radius: var(--radius-md);
  }
  .video-embed-set__shared-label {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.06em;
    color: var(--color-navy);
    margin-bottom: 4px;
    text-transform: uppercase;
  }
  .video-embed-set__shared-text {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 13.5px;
    line-height: 1.7;
    color: var(--color-text);
  }
  .video-embed-set__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 16px;
  }
  .video-card {
    background: var(--color-bg-white);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .video-card__head {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 14px;
    background: var(--color-bg-section);
    border-bottom: 1px solid var(--color-border-light);
  }
  .video-card__num {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--color-gold);
    letter-spacing: 0.04em;
    font-feature-settings: 'tnum';
  }
  .video-card__tool {
    margin: 0;
    font-family: var(--font-serif);
    font-size: 14.5px;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.4;
  }
  .video-card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--color-navy);
  }
  .video-card__iframe,
  .video-card__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }
  .video-card__coming-soon {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    background: linear-gradient(135deg, var(--color-navy) 0%, #1a2e4d 100%);
    color: var(--color-gold);
    font-family: var(--font-sans);
    text-align: center;
    padding: 12px;
  }
  .video-card__coming-soon-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    margin-bottom: 2px;
  }
  .video-card__coming-soon-text {
    font-size: 13.5px;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: #fff;
  }
  .video-card__coming-soon-sub {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.12em;
    color: var(--color-gold);
    text-transform: uppercase;
  }
  .video-card__foot {
    padding: 12px 14px;
    border-top: 1px solid var(--color-border-light);
    font-family: var(--font-sans);
  }
  .video-card__prompt {
    margin: 0 0 6px;
    font-size: 12px;
    color: var(--color-text);
    line-height: 1.6;
  }
  .video-card__prompt:last-child {
    margin-bottom: 0;
  }
  .video-card__prompt-label {
    font-weight: 700;
    color: var(--color-navy);
    margin-right: 4px;
  }
  .video-card__note {
    margin: 0;
    font-size: 11.5px;
    color: var(--color-muted);
    line-height: 1.6;
  }
  .video-card__source {
    margin: 0 0 8px;
    padding: 8px 10px;
    background: var(--color-bg-section);
    border-left: 2px solid var(--color-gold);
    border-radius: var(--radius-sm, 4px);
    font-size: 11.5px;
    line-height: 1.6;
    color: var(--color-text);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
  }
  .video-card__source-badge {
    display: inline-block;
    background: var(--color-gold);
    color: var(--color-navy);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 2px 6px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .video-card__source-link {
    color: var(--color-navy);
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .video-card__source-link:hover {
    color: var(--color-gold);
  }
  .video-card__source-text {
    color: var(--color-navy);
    font-weight: 600;
  }
  .video-card__source-date {
    color: var(--color-muted);
    font-size: 11px;
    margin-left: auto;
  }
  @media (max-width: 768px) {
    .video-embed-set__grid {
      grid-template-columns: 1fr;
    }
    .video-card__head { padding: 10px 12px; }
    .video-card__tool { font-size: 13.5px; }
  }
</style>
