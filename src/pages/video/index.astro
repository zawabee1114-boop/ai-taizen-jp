// ----------------------------------------------------------------
// 構造化データ追加分（seo-optimizer 2026-05-08 構築）
// ----------------------------------------------------------------
// ItemList: 主要AI動画生成ツール8選（toolRows データから生成）
const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "主要AI動画生成ツール 8選",
  "description": "2026年5月時点で利用可能な主要AI動画生成ツール8選（実機検証済み）",
  "itemListOrder": "https://schema.org/ItemListOrderAscending",
  "numberOfItems": toolRows.length,
  "itemListElement": toolRows.map((row, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "SoftwareApplication",
      "name": row.label,
      "applicationCategory": "MultimediaApplication",
      "applicationSubCategory": "AI Video Generation",
      "operatingSystem": "Web",
      "description": (row.cells.strength || '') + ' / ' + (row.cells.rec_use || ''),
      "offers": {
        "@type": "Offer",
        "price": row.cells.price || '',
        "priceCurrency": (row.cells.price && row.cells.price.startsWith('¥')) ? 'JPY' : 'USD',
      },
    },
  })),
};

// HowTo: 失敗例 → 改善後プロンプト の書き方（promptSamples の代表4ステップを構造化）
// AIO/LLMO 引用源化のため、汎用的な「主語・カメラワーク・光・スタイル」の4要素を採用
const howToJsonLd = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "AI動画生成で失敗しないプロンプトの書き方",
  "description": "AI動画生成ツールで望み通りの動画を出力するための、失敗例→改善後の4ステップ。主語・場所・カメラワーク・スタイルの4要素を必ず明文化することで成功率が大幅に向上する。",
  "totalTime": "PT5M",
  "supply": [
    { "@type": "HowToSupply", "name": "AI動画生成サービスのアカウント（Runway / Veo / Kling 等）" },
  ],
  "tool": [
    { "@type": "HowToTool", "name": "テキストエディタ（プロンプト下書き用）" },
  ],
  "step": [
    {
      "@type": "HowToStep",
      "position": 1,
      "name": "主語・場所・時間帯を必ず明記する",
      "text": "「女性が歩いている」のような抽象プロンプトでは AI が想像で補うため毎回違う動画が出力される。「20代の日本人女性、白いトレンチコート、東京の銀座の歩道を午後の柔らかい光の中でゆっくり歩く」のように、誰が・どこで・いつを必ず明記する。",
      "url": `${pageUrl}#prompt-tips`,
    },
    {
      "@type": "HowToStep",
      "position": 2,
      "name": "カメラワークと被写界深度を指定する",
      "text": "「ミディアムショット、横移動カメラワーク、被写界深度浅め」のようにカメラの位置・移動方向・ピント表現を指示する。これにより同じ被写体でも映像クオリティが大きく変わる。",
      "url": `${pageUrl}#prompt-tips`,
    },
    {
      "@type": "HowToStep",
      "position": 3,
      "name": "光の質感と雰囲気を指定する",
      "text": "「午後の柔らかい光」「夕焼け空」「シネマティック」など照明の方向性と雰囲気を1〜2語で添える。AIは「綺麗」「可愛い」のような抽象的な形容詞を解釈できないため、具体的な光の状態を指示する。",
      "url": `${pageUrl}#prompt-tips`,
    },
    {
      "@type": "HowToStep",
      "position": 4,
      "name": "スタイル指定とレンズ感で仕上げる",
      "text": "「85mm相当のレンズ感」「90年代セルアニメ調」「4K」のように画作りのスタイルを最後に追加する。手の指の崩壊を避けたい場合は『手は画面外に出るアングル』と構図でも回避指示を入れる。",
      "url": `${pageUrl}#prompt-tips`,
    },
  ],
};

// VideoObject: 同一プロンプト比較動画 5本
// 注: comparisonVideos の embedUrl は現時点プレースホルダ（dQw4w9WgXcQ）。
// CEO の実機検証＋YouTubeアップロード後、自動的に正しい contentUrl/embedUrl/thumbnailUrl が反映される構造。
const videoObjectsJsonLd = comparisonVideos.map((v: any) => {
  const match = (v.embedUrl || '').match(/embed\/([^/?]+)/);
  const videoId = match ? match[1] : '';
  const watchUrl = videoId ? `https://www.youtube.com/watch?v=${videoId}` : v.embedUrl;
  return {
    "@context": "https://schema.org",
    "@type": "VideoObject",
    "name": `${v.tool} で生成「${sharedPromptVideo}」`,
    "description": `同一プロンプト「${sharedPromptVideo}」を ${v.tool} で生成した検証動画。${v.note || ''}`,
    "thumbnailUrl": videoId ? [`https://img.youtube.com/vi/${videoId}/hqdefault.jpg`] : [`${siteMeta.siteUrl}${siteMeta.ogImage}`],
    "uploadDate": publishedAt,
    "contentUrl": watchUrl,
    "embedUrl": v.embedUrl,
    "publisher": {
      "@type": "Organization",
      "@id": `${siteMeta.siteUrl}/#organization`,
      "name": siteMeta.siteName,
    },
  };
});

const jsonLdAdditional: Record<string, any>[] = [
  itemListJsonLd,
  howToJsonLd,
  ...videoObjectsJsonLd,
];

const allJsonLd = [articleJsonLd, ...jsonLdAdditional];
